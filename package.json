    "lodash-es": "^4.17.23",
    "lucide-vue-next": "^0.577.0",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
